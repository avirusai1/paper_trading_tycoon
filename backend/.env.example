# Paper Trading Tycoon — Laravel Environment Configuration Template
#
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# All keys listed here must be present in the production .env.

# ── Application ───────────────────────────────────────────────────────────────

APP_NAME="Paper Trading Tycoon"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

# ── Logging ───────────────────────────────────────────────────────────────────

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=paper_trading_tycoon
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── Cache / Session / Queue ───────────────────────────────────────────────────

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# In production at 100K+ users, switch CACHE_DRIVER and QUEUE_CONNECTION to redis.
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@papertradingtycoon.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Firebase (Push Notifications) ─────────────────────────────────────────────

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVER_KEY=your_fcm_server_key

# ── Market Data Provider ──────────────────────────────────────────────────────
# Selected provider determined in ADR-002 (Milestone 3).

MARKET_DATA_PROVIDER=alpha_vantage
STOCK_DATA_API_KEY=your_stock_data_api_key
STOCK_DATA_BASE_URL=https://www.alphavantage.co/query

# ── Security ──────────────────────────────────────────────────────────────────

# Sanctum token expiry in minutes. 0 = never.
SANCTUM_TOKEN_EXPIRY_MINUTES=60

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Runtime defaults — managed via Admin Panel at runtime.
# These .env values are the hardcoded fallback if DB flags are unavailable.

FLAG_CRYPTO_TRADING=false
FLAG_OPTIONS_TRADING=false
FLAG_BATTLE_PASS=false
FLAG_AI_COACH=false
FLAG_COPY_TRADING=false
FLAG_TOURNAMENTS=false

# ── Game Economy Defaults (overridden by Rules Engine in DB) ──────────────────

STARTING_VIRTUAL_CASH_PAISE=100000000
